Options +FollowSymLinks -Indexes
RewriteEngine On
RewriteBase /

# Cho phép truy cập trực tiếp vào file và thư mục thực sự tồn tại
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# API - file .php tồn tại trực tiếp thì đã được bắt ở trên
# Nếu URL không có .php, thêm vào để Apache tìm đúng file
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(api/.+?)/?$ $1.php [L]

# ─── Trang Admin ────────────────────────────────────────────────────────────
RewriteRule ^admin/?$                   admin/index.html [L]
RewriteRule ^admin/login/?$             admin/login.html [L]
RewriteRule ^admin/transactions/?$      admin/transactions.html [L]
RewriteRule ^admin/packages/?$          admin/packages.html [L]
RewriteRule ^admin/package-history/?$   admin/package_history.html [L]
RewriteRule ^admin/giftcodes/?$         admin/giftcodes.html [L]

# ─── Trang Người Dùng ────────────────────────────────────────────────────────
RewriteRule ^login/?$       login.html [L]
RewriteRule ^register/?$    register.html [L]
RewriteRule ^packages/?$    packages.html [L]
RewriteRule ^game/sunwin/?$           games/sunwin.html [L]
RewriteRule ^game/baccarat/?$         games/baccarat.html [L]
RewriteRule ^game/baccarat-table/?$   games/baccarat-table.html [L]
RewriteRule ^giftcode/?$    giftcode.html [L]
RewriteRule ^account/?$     account.html [L]
RewriteRule ^deposit/?$     deposit.html [L]
RewriteRule ^history/?$     history.html [L]
RewriteRule ^support/?$     support.html [L]
