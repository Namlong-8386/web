Options +FollowSymLinks -Indexes
RewriteEngine On
RewriteBase /

# Cho phép truy cập trực tiếp vào file và thư mục thực sự tồn tại
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# API - file .php tồn tại trực tiếp thì đã được bắt ở trên
# Nếu URL không có .php, thêm vào để Apache tìm đúng file
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(api/.+?)/?$ $1.php [L]

# ─── Trang Admin ────────────────────────────────────────────────────────────
RewriteRule ^admin/?$                   admin/index.php [L]
RewriteRule ^admin/login/?$             admin/login.php [L]
RewriteRule ^admin/transactions/?$      admin/transactions.php [L]
RewriteRule ^admin/packages/?$          admin/packages.php [L]
RewriteRule ^admin/package-history/?$   admin/package_history.php [L]
RewriteRule ^admin/giftcodes/?$         admin/giftcodes.php [L]
RewriteRule ^admin/keys/?$              admin/keys.php [L]

# ─── Trang Người Dùng ────────────────────────────────────────────────────────
RewriteRule ^login/?$       login.php [L]
RewriteRule ^register/?$    register.php [L]
RewriteRule ^packages/?$    packages.php [L]
RewriteRule ^game/sunwin/?$           games/sunwin.php [L]
RewriteRule ^game/baccarat/?$         games/baccarat.php [L]
RewriteRule ^game/baccarat-table/?$   games/baccarat-table.php [L]
RewriteRule ^giftcode/?$    giftcode.php [L]
RewriteRule ^account/?$     account.php [L]
RewriteRule ^deposit/?$     deposit.php [L]
RewriteRule ^history/?$     history.php [L]
RewriteRule ^support/?$     support.php [L]
RewriteRule ^apk/?$         apk.php [L]
RewriteRule ^buy-key/?$     buy-key.php [L]
RewriteRule ^free-key/?$    free-key.php [L]
RewriteRule ^apk-key/?$     apk-key.php [L]
RewriteRule ^payment-qr/?$  payment-qr.php [L]
